generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// AUTH / USERS
// ──────────────────────────────────────────────

enum UserRole {
  USER
  SHOP_OWNER
  ADMIN
}

model User {
  id          String    @id @default(cuid())
  email       String?   @unique
  name        String?
  image       String?
  phone       String?
  password    String?
  role        UserRole  @default(USER)
  isAnonymous Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  appraisals   Appraisal[]
  appointments Appointment[]
  ownedShop    Shop?     @relation("ShopOwner")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// APPRAISALS
// ──────────────────────────────────────────────

enum AppraisalStatus {
  DRAFT
  ANALYZING
  CONVERSING
  APPRAISED
  APPOINTMENT_BOOKED
  // Future: OFFERED, ACCEPTED, SHIPPED, COMPLETED, EXPIRED
}

enum MetalType {
  GOLD
  SILVER
  PLATINUM
  PALLADIUM
  UNKNOWN
}

model Appraisal {
  id     String          @id @default(cuid())
  userId String
  status AppraisalStatus @default(DRAFT)

  // AI analysis results (populated incrementally)
  metalType          MetalType?
  karatPurity        Float?
  estimatedWeight    Float?
  estimatedWeightLow  Float?
  estimatedWeightHigh Float?
  weightSource       String?
  description        String?
  aiConfidence       Float?
  itemCategory       String?

  // Pricing snapshot (frozen at appraisal time)
  spotPricePerGram    Float?
  spotPriceCurrency   String?  @default("USD")
  pureMetalWeight     Float?
  meltValue           Float?
  estimatedPayoutLow  Float?
  estimatedPayoutHigh Float?

  // User-provided info
  userNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id])
  images        AppraisalImage[]
  messages      AppraisalMessage[]
  appointments  Appointment[]
  notifications Notification[]

  @@index([userId, status])
  @@index([createdAt])
}

model AppraisalImage {
  id          String   @id @default(cuid())
  appraisalId String
  url         String
  key         String
  order       Int      @default(0)
  imageType   String?  // "overview", "scale_reference", "stamp_closeup"
  createdAt   DateTime @default(now())

  appraisal Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)

  @@index([appraisalId])
}

model AppraisalMessage {
  id          String   @id @default(cuid())
  appraisalId String
  role        String
  content     String
  metadata    Json?
  createdAt   DateTime @default(now())

  appraisal Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)

  @@index([appraisalId, createdAt])
}

// ──────────────────────────────────────────────
// PAWN SHOPS
// ──────────────────────────────────────────────

model Shop {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  address     String
  city        String
  state       String
  zipCode     String
  latitude    Float
  longitude   Float
  phone       String?
  email       String?
  website     String?
  imageUrl    String?
  description String?

  ownerId String? @unique
  owner   User?   @relation("ShopOwner", fields: [ownerId], references: [id])

  acceptsGold     Boolean @default(true)
  acceptsSilver   Boolean @default(true)
  acceptsPlatinum Boolean @default(false)
  payoutFactor    Float   @default(0.60)
  rating          Float?

  hours Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments  Appointment[]
  notifications Notification[]

  @@index([latitude, longitude])
  @@index([city, state])
}

// ──────────────────────────────────────────────
// APPOINTMENTS
// ──────────────────────────────────────────────

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Appointment {
  id          String            @id @default(cuid())
  userId      String
  appraisalId String
  shopId      String
  status      AppointmentStatus @default(PENDING)
  scheduledAt DateTime
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  appraisal Appraisal @relation(fields: [appraisalId], references: [id])
  shop      Shop      @relation(fields: [shopId], references: [id])

  @@index([userId])
  @@index([shopId, scheduledAt])
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  shopId      String
  appraisalId String
  type        String   @default("NEW_APPRAISAL")
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  shop      Shop      @relation(fields: [shopId], references: [id])
  appraisal Appraisal @relation(fields: [appraisalId], references: [id])

  @@index([shopId, read])
  @@index([appraisalId])
}

// ──────────────────────────────────────────────
// SPOT PRICE CACHE
// ──────────────────────────────────────────────

model SpotPriceCache {
  id           String    @id @default(cuid())
  metal        MetalType
  pricePerGram Float
  pricePerOz   Float
  source       String
  fetchedAt    DateTime  @default(now())

  @@index([metal, fetchedAt])
}
